{
  "name": "mst-cli",
  "version": "0.1.0",
  "description": "Interactive CLI chat client for Microsoft Teams",
  "type": "module",
  "bin": {
    "mst-cli": "./bin/mst-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.0",
    "@inquirer/prompts": "^7.0.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "fuse.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
