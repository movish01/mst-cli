{
  "name": "msteams-cli",
  "version": "0.1.0",
  "description": "Interactive CLI chat client for Microsoft Teams",
  "type": "module",
  "bin": {
    "msteams-cli": "./bin/msteams-cli.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "microsoft-teams",
    "teams",
    "chat",
    "cli",
    "repl",
    "graph-api"
  ],
  "repository": "github:movish01/mst-cli",
  "author": "Movish Verma",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.0",
    "@inquirer/prompts": "^7.0.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "fuse.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
